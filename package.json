{
  "name": "claude-print-assistant",
  "description": "AI-powered print management assistant for print shops",
  "author": "Muhammadimranasif",
  "private": true,
  "version": "1.1.6",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "dist": "npm run build && electron-builder",
    "dist:fast": "electron-builder --publish never",
    "publish": "npm run build && electron-builder --publish always",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "electron-updater": "^6.3.9",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^33.4.11",
    "electron-builder": "^26.15.2",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  },
  "build": {
    "appId": "com.aipa.claude-print-assistant",
    "productName": "AI Print Assistant",
    "copyright": "Copyright © 2026 AI Print Assistant",
    "directories": {
      "output": "builds/v${version}"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.cjs",
      "package.json",
      "assets/**/*"
    ],
    "extraResources": [],
    "artifactName": "AI-Print-Assistant-Setup-${version}.${ext}",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AI Print Assistant"
    },
    "publish": {
      "provider": "github",
      "owner": "Muhammadimranasif",
      "repo": "AI-Print-Assistant",
      "private": false,
      "releaseType": "release"
    }
  }
}
